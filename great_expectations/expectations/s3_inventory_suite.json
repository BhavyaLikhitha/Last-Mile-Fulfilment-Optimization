{
  "expectation_suite_name": "s3_inventory_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "snapshot_date", "warehouse_id", "product_id", "opening_stock",
          "units_sold", "units_received", "units_returned", "closing_stock",
          "stockout_flag", "below_safety_stock_flag", "reorder_triggered_flag",
          "units_on_order", "days_of_supply", "holding_cost", "inventory_value",
          "created_at", "updated_at", "batch_id"
        ]
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 3500, "max_value": 4500},
      "meta": {"notes": "8 warehouses * 500 products = 4000 rows/day"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "closing_stock", "min_value": 0}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "holding_cost", "min_value": 0}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {"column": "warehouse_id", "regex": "^WH-\\d{3}$"}
    }
  ],
  "meta": {
    "great_expectations_version": "1.3.0"
  }
}
