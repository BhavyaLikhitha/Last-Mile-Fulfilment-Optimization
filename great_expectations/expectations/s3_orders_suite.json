{
  "expectation_suite_name": "s3_orders_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "order_id", "order_date", "order_timestamp", "customer_id",
          "assigned_warehouse_id", "nearest_warehouse_id", "allocation_strategy",
          "order_priority", "total_items", "total_amount",
          "total_fulfillment_cost", "order_status", "return_flag",
          "experiment_id", "experiment_group", "created_at", "updated_at", "batch_id"
        ]
      },
      "meta": {"notes": "Schema conformance — catch Lambda column changes"}
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 3000, "max_value": 12000},
      "meta": {"notes": "DAILY_ORDERS=5000 with 10% YoY growth, allow 3K-12K for variance"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {"column": "order_id", "regex": "^ORD-\\d+.*$"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "total_amount", "min_value": 0.01}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "order_status",
        "value_set": ["Delivered", "Shipped", "Processing", "Pending", "Cancelled"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "order_priority",
        "value_set": ["Standard", "Express", "Same-Day"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {"column": "assigned_warehouse_id", "regex": "^WH-\\d{3}$"}
    }
  ],
  "meta": {
    "great_expectations_version": "1.3.0"
  }
}
